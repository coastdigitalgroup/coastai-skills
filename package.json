{
  "name": "@coastdigitalgroup/coastai-skills",
  "version": "0.1.0",
  "description": "MCP server for the coast-ai-skills library. Exposes website design, development, and growth skills to AI agents via list_skills and get_skill tools.",
  "type": "module",
  "bin": {
    "coastai-skills": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "files": [
    "dist",
    "website-design",
    "website-development",
    "website-growth"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-skills",
    "website-design",
    "website-development"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=18"
  }
}
